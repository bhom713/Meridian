import sys
from PyQt6.QtWidgets import (QApplication, QMainWindow, QWidget, QVBoxLayout,
                              QHBoxLayout, QLabel, QTextEdit, QPushButton,
                              QLineEdit, QScrollArea, QFrame)
from PyQt6.QtCore import Qt, QTimer, QDateTime, QThread, pyqtSignal
from PyQt6.QtGui import QFont
import requests

GROQ_API_KEY = "your_groq_api_key_here"
WEATHER_API_KEY = "your_openweathermap_key_here"
NEWS_API_KEY = "your_newsapi_key_here"

class AIWorker(QThread):
    response_ready = pyqtSignal(str)

    def __init__(self, prompt):
        super().__init__()
        self.prompt = prompt

    def run(self):
        try:
            url = "https://api.groq.com/openai/v1/chat/completions"
            headers = {
                "Authorization": f"Bearer {GROQ_API_KEY}",
                "Content-Type": "application/json"
            }
            payload = {
                "model": "llama-3.3-70b-versatile",
                "messages": [{"role": "user", "content": self.prompt}]
            }
            response = requests.post(url, headers=headers, json=payload)
            data = response.json()
            text = data["choices"][0]["message"]["content"]
            self.response_ready.emit(text)
        except Exception as e:
            self.response_ready.emit(f"Error: {str(e)}")

class WeatherWorker(QThread):
    weather_ready = pyqtSignal(dict)

    def __init__(self, city):
        super().__init__()
        self.city = city

    def run(self):
        try:
            url = f"http://api.openweathermap.org/data/2.5/forecast?q={self.city}&appid={WEATHER_API_KEY}&units=imperial&cnt=7"
            response = requests.get(url)
            data = response.json()
            self.weather_ready.emit(data)
        except Exception as e:
            self.weather_ready.emit({"error": str(e)})

class NewsWorker(QThread):
    news_ready = pyqtSignal(list)

    def run(self):
        try:
            url = f"https://newsapi.org/v2/top-headlines?country=us&pageSize=5&apiKey={NEWS_API_KEY}"
            response = requests.get(url)
            data = response.json()
            self.news_ready.emit(data.get("articles", []))
        except Exception as e:
            self.news_ready.emit([])

class Meridian(QMainWindow):
    def __init__(self):
        super().__init__()
        self.setWindowTitle("Meridian")
        self.setMinimumSize(1000, 700)
        self.setup_ui()
        self.setup_timer()
        QTimer.singleShot(1000, self.refresh_all)

    def setup_ui(self):
        self.setStyleSheet("""
            QMainWindow, QWidget {
                background-color: #1a1a1a;
                color: #e0e0e0;
            }
            QLabel {
                color: #e0e0e0;
            }
            QTextEdit, QLineEdit {
                background-color: #2a2a2a;
                color: #e0e0e0;
                border: 1px solid #3a3a3a;
                border-radius: 6px;
                padding: 8px;
                font-size: 13px;
            }
            QPushButton {
                background-color: #2a2a2a;
                color: #e0e0e0;
                border: 1px solid #3a3a3a;
                border-radius: 6px;
                padding: 6px 16px;
                font-size: 12px;
            }
            QPushButton:hover {
                background-color: #3a3a3a;
            }
            QScrollArea {
                background-color: #1a1a1a;
                border: none;
            }
        """)

        central = QWidget()
        self.setCentralWidget(central)
        main_layout = QVBoxLayout(central)
        main_layout.setContentsMargins(20, 20, 20, 20)
        main_layout.setSpacing(10)

        # --- TIME ---
        self.time_label = QLabel()
        self.time_label.setAlignment(Qt.AlignmentFlag.AlignCenter)
        self.time_label.setFont(QFont("Helvetica", 26))
        main_layout.addWidget(self.time_label)

        # --- TWO COLUMNS ---
        columns = QHBoxLayout()
        columns.setSpacing(15)

        # LEFT — Notepad / AI
        ai_frame = self.make_section("Notepad / AI")
        ai_inner = QVBoxLayout()

        self.response_area = QTextEdit()
        self.response_area.setReadOnly(True)
        self.response_area.setPlaceholderText("AI responses appear here...")
        ai_inner.addWidget(self.response_area)

        self.notepad = QTextEdit()
        self.notepad.setPlaceholderText("Type a note or ask AI anything...")
        self.notepad.setMaximumHeight(100)
        ai_inner.addWidget(self.notepad)

        btn_row = QHBoxLayout()
        self.send_btn = QPushButton("Ask AI")
        self.send_btn.clicked.connect(self.ask_ai)
        self.clear_btn = QPushButton("Clear")
        self.clear_btn.clicked.connect(self.clear_all)
        btn_row.addWidget(self.send_btn)
        btn_row.addWidget(self.clear_btn)
        btn_row.addStretch()
        ai_inner.addLayout(btn_row)

        ai_frame.layout().addLayout(ai_inner)
        columns.addWidget(ai_frame, 55)

        # RIGHT — Weather and News
        right_scroll = QScrollArea()
        right_scroll.setWidgetResizable(True)
        right_scroll.setFrameShape(QFrame.Shape.NoFrame)
        right_widget = QWidget()
        right = QVBoxLayout(right_widget)
        right.setSpacing(10)
        right_scroll.setWidget(right_widget)

        # Weather
        weather_frame = self.make_section("Weather")
        weather_inner = QVBoxLayout()
        loc_row = QHBoxLayout()
        self.city_input = QLineEdit()
        self.city_input.setPlaceholderText("Enter city...")
        self.weather_btn = QPushButton("Update")
        self.weather_btn.clicked.connect(self.fetch_weather)
        loc_row.addWidget(self.city_input)
        loc_row.addWidget(self.weather_btn)
        weather_inner.addLayout(loc_row)
        self.weather_label = QLabel("Enter a city to see weather")
        self.weather_label.setWordWrap(True)
        weather_inner.addWidget(self.weather_label)
        self.forecast_label = QLabel("")
        self.forecast_label.setWordWrap(True)
        self.forecast_label.setStyleSheet("color: #aaaaaa; font-size: 11px;")
        weather_inner.addWidget(self.forecast_label)
        weather_frame.layout().addLayout(weather_inner)
        right.addWidget(weather_frame)

        # News
        news_frame = self.make_section("News")
        self.news_label = QLabel("Loading news...")
        self.news_label.setWordWrap(True)
        self.news_label.setStyleSheet("font-size: 12px;")
        news_frame.layout().addWidget(self.news_label)
        right.addWidget(news_frame)

        right.addStretch()
        columns.addWidget(right_scroll, 45)
        main_layout.addLayout(columns)

        self.update_time()

    def make_section(self, title):
        frame = QFrame()
        frame.setStyleSheet("""
            QFrame {
                background-color: #222222;
                border: 1px solid #333333;
                border-radius: 8px;
                padding: 5px;
            }
        """)
        layout = QVBoxLayout(frame)
        label = QLabel(title.upper())
        label.setStyleSheet("color: #888888; font-size: 11px; letter-spacing: 2px;")
        layout.addWidget(label)
        return frame

    def setup_timer(self):
        self.timer = QTimer()
        self.timer.timeout.connect(self.update_time)
        self.timer.start(1000)
        self.refresh_timer = QTimer()
        self.refresh_timer.timeout.connect(self.refresh_all)
        self.refresh_timer.start(300000)

    def update_time(self):
        current = QDateTime.currentDateTime()
        self.time_label.setText(current.toString("dddd, MMMM d  —  h:mm:ss ap"))

    def refresh_all(self):
        self.fetch_news()

    def fetch_weather(self):
        city = self.city_input.text().strip()
        if not city:
            return
        self.weather_label.setText("Loading...")
        self.weather_worker = WeatherWorker(city)
        self.weather_worker.weather_ready.connect(self.show_weather)
        self.weather_worker.start()

    def show_weather(self, data):
        if "error" in data or data.get("cod") != "200":
            self.weather_label.setText("City not found or error.")
            return
        current = data["list"][0]
        temp = current["main"]["temp"]
        desc = current["weather"][0]["description"].capitalize()
        humidity = current["main"]["humidity"]
        self.weather_label.setText(f"{temp:.1f}°F  —  {desc}  —  Humidity: {humidity}%")
        forecast_lines = []
        seen_days = []
        for item in data["list"]:
            date = item["dt_txt"].split(" ")[0]
            if date not in seen_days:
                seen_days.append(date)
                t = item["main"]["temp"]
                d = item["weather"][0]["description"].capitalize()
                forecast_lines.append(f"{date}:  {t:.1f}°F  —  {d}")
            if len(seen_days) >= 7:
                break
        self.forecast_label.setText("\n".join(forecast_lines))

    def fetch_news(self):
        self.news_worker = NewsWorker()
        self.news_worker.news_ready.connect(self.show_news)
        self.news_worker.start()

    def show_news(self, articles):
        if not articles:
            self.news_label.setText("Could not load news.")
            return
        lines = []
        for i, a in enumerate(articles[:5]):
            title = a.get("title", "No title")
            source = a.get("source", {}).get("name", "")
            lines.append(f"{i+1}. {title}  —  {source}")
        self.news_label.setText("\n\n".join(lines))

    def ask_ai(self):
        prompt = self.notepad.toPlainText().strip()
        if not prompt:
            return
        self.response_area.setText("Thinking...")
        self.send_btn.setEnabled(False)
        self.worker = AIWorker(prompt)
        self.worker.response_ready.connect(self.show_response)
        self.worker.start()

    def show_response(self, text):
        self.response_area.setText(text)
        self.send_btn.setEnabled(True)

    def clear_all(self):
        self.notepad.clear()
        self.response_area.clear()

if __name__ == "__main__":
    app = QApplication(sys.argv)
    window = Meridian()
    window.show()
    sys.exit(app.exec())
